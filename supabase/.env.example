# Copy to supabase/.env (gitignored), fill in real values, then source it
# before running local Supabase CLI commands that need these providers, e.g.:
#   set -a && source supabase/.env && set +a && pnpm supabase start
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
SUPABASE_AUTH_EXTERNAL_AZURE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_AZURE_SECRET=
# Email that gets auto-promoted to 'owner' on first sign-in (bootstrap-owner
# Edge Function). See spec section 4.1.
OWNER_EMAIL=
