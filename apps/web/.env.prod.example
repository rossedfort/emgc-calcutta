# Copy to apps/web/.env.prod (gitignored). Values are the remote/hosted
# Supabase project's URL and publishable key — same ones Vercel's dashboard
# has configured for the actual deployment. Get them via:
#   pnpm supabase projects api-keys --project-ref <ref>
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_PUBLISHABLE_KEY=
